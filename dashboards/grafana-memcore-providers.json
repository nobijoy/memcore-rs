{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "description": "TEMPLATE: Memcore providers. Prefer admin provider-usage until Prometheus provider metrics exist. Never plot prompts.",
  "editable": true,
  "id": null,
  "panels": [
    {
      "type": "timeseries",
      "title": "Provider requests (intended)",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_provider_requests_total[5m])) by (provider, model)",
          "legendFormat": "{{provider}} {{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Provider latency p95 (intended)",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(memcore_provider_request_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Provider failures (intended)",
      "id": 3,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_provider_failures_total[5m])) by (provider)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Provider retries (intended)",
      "id": 4,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_provider_retries_total[5m])) by (provider)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Circuit breaker opens (intended)",
      "id": 5,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_provider_circuit_breaker_open_total[5m])) by (provider)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Vector search latency (intended)",
      "id": 6,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(memcore_vector_search_duration_seconds_bucket[5m])) by (le, backend))",
          "legendFormat": "{{backend}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["memcore", "template", "providers"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Memcore Providers (template)",
  "uid": "memcore-providers-template",
  "version": 1
}
