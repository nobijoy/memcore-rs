{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping memcore /metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "TEMPLATE: Memcore service overview using Prometheus scrape metrics from GET /metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "HTTP requests (total)",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(memcore_http_requests_total)",
          "legendFormat": "requests",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "HTTP errors (4xx+5xx)",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(memcore_http_request_errors_total)",
          "legendFormat": "errors",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Mean latency (s)",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_http_request_duration_seconds_sum[5m])) / clamp_min(sum(rate(memcore_http_request_duration_seconds_count[5m])), 1e-9)",
          "legendFormat": "mean_s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error ratio (approx)",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_http_request_errors_total[5m])) / clamp_min(sum(rate(memcore_http_requests_total[5m])), 1e-9)",
          "legendFormat": "error_ratio",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request rate",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_http_requests_total[5m]))",
          "legendFormat": "rps",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_http_request_errors_total[5m]))",
          "legendFormat": "errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory / search / context rates",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_memory_create_total[5m]))",
          "legendFormat": "memory_create",
          "refId": "A"
        },
        {
          "expr": "sum(rate(memcore_memory_search_total[5m]))",
          "legendFormat": "search",
          "refId": "B"
        },
        {
          "expr": "sum(rate(memcore_context_requests_total[5m]))",
          "legendFormat": "context",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(memcore_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Provider failures",
      "id": 9,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_provider_failures_total[5m])) by (provider)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Background job failures",
      "id": 10,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_background_job_failures_total[5m])) by (job_kind)",
          "legendFormat": "{{job_kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache hit rate",
      "id": 11,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_context_cache_hits_total[5m])) / clamp_min(sum(rate(memcore_context_cache_hits_total[5m])) + sum(rate(memcore_context_cache_misses_total[5m])), 1e-9)",
          "legendFormat": "hit_ratio",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Quota rejections",
      "id": 12,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_quota_rejections_total[5m])) by (quota_type)",
          "legendFormat": "{{quota_type}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["memcore", "template", "overview"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Memcore Overview (template)",
  "uid": "memcore-overview-template",
  "version": 2
}
