{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "description": "TEMPLATE: Memcore HTTP API dashboard. Mix of implemented counters and intended labeled metrics.",
  "editable": true,
  "id": null,
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests by route (intended)",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_http_requests_total[5m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency by route p95 (intended)",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(memcore_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "4xx rate (intended)",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_http_request_errors_total{status_class=\"4xx\"}[5m]))",
          "legendFormat": "4xx/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx rate (intended)",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_http_request_errors_total{status_class=\"5xx\"}[5m]))",
          "legendFormat": "5xx/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth failures (intended)",
      "id": 5,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_auth_failures_total[5m])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rate limited requests (intended)",
      "id": 6,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_rate_limited_requests_total[5m]))",
          "legendFormat": "rate_limited/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Coarse errors (implemented counter)",
      "id": 7,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_api_errors_total[5m]))",
          "legendFormat": "api_errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory create / search / context (implemented)",
      "id": 8,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(memcore_memory_add_requests_total[5m]))",
          "legendFormat": "create",
          "refId": "A"
        },
        {
          "expr": "sum(rate(memcore_memory_search_requests_total[5m]))",
          "legendFormat": "search",
          "refId": "B"
        },
        {
          "expr": "sum(rate(memcore_context_requests_total[5m]))",
          "legendFormat": "context",
          "refId": "C"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["memcore", "template", "api"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
