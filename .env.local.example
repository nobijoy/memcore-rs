# Local development quickstart (SQLite + mock vector + mock providers).
# Copy to `.env` or use:  cp .env.local.example .env
#
# Binary:  cargo run -p memcore-api
# Docker:  docker compose -f docker/docker-compose.local.yml up --build
#
# No Postgres, Qdrant, Redis, OpenAI, or LanceDB required.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
MEMCORE_ENV=development
MEMCORE_HOST=0.0.0.0
MEMCORE_PORT=8080

# -----------------------------------------------------------------------------
# Auth (dev mode for local only)
# -----------------------------------------------------------------------------
MEMCORE_AUTH_ENABLED=true
MEMCORE_AUTH_MODE=dev
MEMCORE_DEV_API_KEY=memcore_dev_key
# Optional pepper for experimenting with database auth mode locally:
# MEMCORE_API_KEY_PEPPER=CHANGE_ME_LOCAL_PEPPER

# -----------------------------------------------------------------------------
# Database (SQLite)
# -----------------------------------------------------------------------------
MEMCORE_STORAGE_MODE=embedded
MEMCORE_FACT_BACKEND=sqlite
MEMCORE_EVENT_BACKEND=sqlite
MEMCORE_DATABASE_URL=sqlite://./data/memcore.db
MEMCORE_DATABASE_MIGRATIONS_ENABLED=true
MEMCORE_DATABASE_MIGRATION_MODE=auto
MEMCORE_DATABASE_REQUIRE_CLEAN_MIGRATIONS=true

# -----------------------------------------------------------------------------
# Vector store (mock — do not leave VECTOR_BACKEND unset or it may default to LanceDB)
# -----------------------------------------------------------------------------
MEMCORE_VECTOR_BACKEND=mock

# -----------------------------------------------------------------------------
# LLM / embedding (mock)
# -----------------------------------------------------------------------------
MEMCORE_LLM_PROVIDER=mock
MEMCORE_LLM_MODEL=mock-llm
MEMCORE_EMBEDDING_PROVIDER=mock
MEMCORE_EMBEDDING_MODEL=mock-embedding

# -----------------------------------------------------------------------------
# Redis / cache (disabled)
# -----------------------------------------------------------------------------
MEMCORE_CONTEXT_CACHE_BACKEND=disabled

# -----------------------------------------------------------------------------
# Background jobs (off for local by default)
# -----------------------------------------------------------------------------
MEMCORE_BACKGROUND_JOBS_ENABLED=false
MEMCORE_GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Rate limits / security / observability
# -----------------------------------------------------------------------------
MEMCORE_RATE_LIMIT_ENABLED=true
MEMCORE_RATE_LIMIT_REQUESTS_PER_MINUTE=60
MEMCORE_SECURITY_HEADERS_ENABLED=true
MEMCORE_MAX_REQUEST_BODY_BYTES=1048576
MEMCORE_CORS_ENABLED=false
MEMCORE_ENABLE_PII_REDACTION=true
MEMCORE_MIN_IMPORTANCE=0.55
MEMCORE_LOG_FORMAT=pretty
MEMCORE_LOG_LEVEL=info
MEMCORE_METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# Backup (optional locally)
# -----------------------------------------------------------------------------
MEMCORE_BACKUP_ENABLED=false
MEMCORE_BACKUP_DIR=./backups
MEMCORE_RESTORE_ENABLED=false
