# Production-shaped environment. Placeholders only — never commit real secrets.
# Prefer a platform secret manager; use this file as a checklist for required keys.
#
# Compose example:
#   cp .env.production.example .env.production
#   # edit CHANGE_ME values
#   docker compose --env-file .env.production -f docker/docker-compose.prod.yml up --build -d
#
# Required image features: CARGO_FEATURES=postgres,qdrant
# Validate: ./scripts/ops/validate_env.sh .env.production
# Smoke:    ./scripts/ops/smoke_test.sh https://api.example.com
#
# See docs/ENVIRONMENT.md, docs/DEPLOYMENT.md, docs/runbooks/

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
MEMCORE_ENV=production
MEMCORE_HOST=0.0.0.0
MEMCORE_PORT=8080

# -----------------------------------------------------------------------------
# Auth
# Use database mode with hashed API keys in real production.
# -----------------------------------------------------------------------------
MEMCORE_AUTH_ENABLED=true
MEMCORE_AUTH_MODE=database
MEMCORE_API_KEY_PEPPER=CHANGE_ME_LONG_RANDOM_PEPPER
# Leave unset / empty when using database auth:
# MEMCORE_DEV_API_KEY=

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
MEMCORE_STORAGE_MODE=production
MEMCORE_FACT_BACKEND=postgres
MEMCORE_EVENT_BACKEND=postgres
MEMCORE_POSTGRES_URL=postgres://memcore:CHANGE_ME@postgres:5432/memcore
MEMCORE_DATABASE_MIGRATIONS_ENABLED=true
# Prefer auto after backup, or validate_only when migrations run out-of-band:
MEMCORE_DATABASE_MIGRATION_MODE=auto
MEMCORE_DATABASE_REQUIRE_CLEAN_MIGRATIONS=true

# Docker Postgres bootstrap (compose only; must match MEMCORE_POSTGRES_URL):
POSTGRES_DB=memcore
POSTGRES_USER=memcore
POSTGRES_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# Vector store (Qdrant)
# LanceDB is optional/heavy — not recommended for this compose profile.
# -----------------------------------------------------------------------------
MEMCORE_VECTOR_BACKEND=qdrant
MEMCORE_QDRANT_URL=http://qdrant:6333
MEMCORE_QDRANT_COLLECTION=memcore_vectors

# -----------------------------------------------------------------------------
# LLM / embedding providers
# Set real keys via secret manager; do not paste production keys into git.
# -----------------------------------------------------------------------------
MEMCORE_LLM_PROVIDER=openai
MEMCORE_LLM_MODEL=gpt-4.1-mini
MEMCORE_EMBEDDING_PROVIDER=openai
MEMCORE_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1

MEMCORE_PROVIDER_TIMEOUT_SECONDS=30
MEMCORE_PROVIDER_MAX_RETRIES=2
MEMCORE_PROVIDER_INITIAL_BACKOFF_MS=250
MEMCORE_PROVIDER_MAX_BACKOFF_MS=2000
MEMCORE_PROVIDER_BACKOFF_MULTIPLIER=2.0
MEMCORE_PROVIDER_RETRY_JITTER_ENABLED=true
MEMCORE_PROVIDER_FALLBACK_ENABLED=false
# MEMCORE_LLM_FALLBACK_ORDER=openai
# MEMCORE_EMBEDDING_FALLBACK_ORDER=openai
MEMCORE_PROVIDER_CIRCUIT_BREAKER_ENABLED=true
MEMCORE_PROVIDER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
MEMCORE_PROVIDER_CIRCUIT_BREAKER_RESET_TIMEOUT_SECONDS=60
MEMCORE_PROVIDER_CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=1
MEMCORE_PROVIDER_USAGE_METRICS_ENABLED=true
MEMCORE_PROVIDER_COST_TRACKING_ENABLED=false
MEMCORE_PROVIDER_USAGE_PERSISTENCE_ENABLED=true
MEMCORE_PROVIDER_USAGE_RETENTION_DAYS=180

# -----------------------------------------------------------------------------
# Redis / context cache (optional; requires redis-cache build feature)
# -----------------------------------------------------------------------------
MEMCORE_CONTEXT_CACHE_BACKEND=disabled
# MEMCORE_CONTEXT_CACHE_BACKEND=redis
# MEMCORE_REDIS_URL=redis://:CHANGE_ME@redis:6379/0
# MEMCORE_CONTEXT_CACHE_TTL_SECONDS=300
# MEMCORE_CONTEXT_CACHE_KEY_PREFIX=memcore
# MEMCORE_CONTEXT_CACHE_STAMPEDE_PROTECTION_ENABLED=true
# MEMCORE_CONTEXT_CACHE_LOCK_TIMEOUT_SECONDS=30
# MEMCORE_CONTEXT_CACHE_STALE_WHILE_REVALIDATE_ENABLED=false
# MEMCORE_CONTEXT_CACHE_STALE_TTL_SECONDS=120
# MEMCORE_CONTEXT_CACHE_METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# Background jobs
# -----------------------------------------------------------------------------
MEMCORE_BACKGROUND_JOBS_ENABLED=false
MEMCORE_BACKGROUND_JOB_RUNNER_INTERVAL_SECONDS=60
# MEMCORE_BACKGROUND_JOB_ORG_IDS=org_example
MEMCORE_MEMORY_USAGE_SNAPSHOT_JOB_ENABLED=false
MEMCORE_PROVIDER_USAGE_RETENTION_JOB_ENABLED=false
MEMCORE_MEMORY_RETENTION_JOB_ENABLED=false
MEMCORE_BACKGROUND_JOB_HISTORY_ENABLED=true
MEMCORE_BACKGROUND_JOB_HISTORY_RETENTION_DAYS=30
MEMCORE_BACKGROUND_JOB_LOCK_ENABLED=true
MEMCORE_BACKGROUND_JOB_LOCK_BACKEND=database
MEMCORE_BACKGROUND_JOB_LOCK_TTL_SECONDS=300
# MEMCORE_BACKGROUND_JOB_LOCK_OWNER_ID=
MEMCORE_BACKGROUND_JOB_RETRIES_ENABLED=true
MEMCORE_BACKGROUND_JOB_MAX_RETRIES=2
MEMCORE_GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=30
MEMCORE_BACKGROUND_JOB_SHUTDOWN_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Rate limits / quotas / retention / PII
# -----------------------------------------------------------------------------
MEMCORE_RATE_LIMIT_ENABLED=true
MEMCORE_RATE_LIMIT_REQUESTS_PER_MINUTE=120
MEMCORE_QUOTAS_ENABLED=false
# MEMCORE_MAX_USERS_PER_ORG=0
# MEMCORE_MAX_MEMORIES_PER_USER=0
# MEMCORE_MAX_MEMORIES_PER_ORG=0
# MEMCORE_DAILY_PROVIDER_REQUEST_LIMIT=0
# MEMCORE_DAILY_PROVIDER_TOKEN_LIMIT=0
MEMCORE_RETENTION_ENABLED=false
# MEMCORE_FACT_RETENTION_DAYS=0
# MEMCORE_EVENT_RETENTION_DAYS=0
MEMCORE_ENABLE_PII_REDACTION=true
MEMCORE_MIN_IMPORTANCE=0.55

# -----------------------------------------------------------------------------
# Security / CORS (keep CORS off unless browser clients call the API)
# -----------------------------------------------------------------------------
MEMCORE_SECURITY_HEADERS_ENABLED=true
MEMCORE_MAX_REQUEST_BODY_BYTES=1048576
MEMCORE_CORS_ENABLED=false
# MEMCORE_CORS_ALLOWED_ORIGINS=https://app.example.com
MEMCORE_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
MEMCORE_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Organization-ID
MEMCORE_CORS_EXPOSED_HEADERS=
MEMCORE_CORS_ALLOW_CREDENTIALS=false

# -----------------------------------------------------------------------------
# Backup (SQLite helpers; for Postgres use managed snapshots / pg_dump)
# -----------------------------------------------------------------------------
MEMCORE_BACKUP_ENABLED=false
MEMCORE_BACKUP_DIR=./backups
MEMCORE_BACKUP_MAX_FILES=10
# Never enable restore on shared hosts without a controlled procedure:
MEMCORE_RESTORE_ENABLED=false

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
MEMCORE_LOG_FORMAT=json
MEMCORE_LOG_LEVEL=info
MEMCORE_REQUEST_ID_HEADER=X-Request-ID
MEMCORE_METRICS_ENABLED=false
MEMCORE_METRICS_PATH=/metrics
MEMCORE_METRICS_REQUIRE_AUTH=true
MEMCORE_METRICS_INCLUDE_PROCESS=false

# -----------------------------------------------------------------------------
# Release metadata (prefer build args / CI injection)
# -----------------------------------------------------------------------------
# MEMCORE_BUILD_GIT_SHA=unknown
# MEMCORE_BUILD_TIMESTAMP=unknown
# MEMCORE_BUILD_PROFILE=release
