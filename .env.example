# memcore environment template (generic / shared reference)
#
# Prefer environment-specific files:
#   .env.local.example      → local quickstart
#   .env.staging.example    → staging-shaped stack
#   .env.production.example → production-shaped stack
#
# Copy to `.env` (never commit real secrets). See docs/ENVIRONMENT.md.
# Placeholders only — replace CHANGE_ME values before any real deployment.

# =============================================================================
# Server
# =============================================================================
MEMCORE_ENV=development
MEMCORE_HOST=0.0.0.0
MEMCORE_PORT=8080

# =============================================================================
# Auth
# =============================================================================
MEMCORE_AUTH_ENABLED=true
# dev = plaintext MEMCORE_DEV_API_KEY; database = hashed keys + pepper
MEMCORE_AUTH_MODE=dev
MEMCORE_DEV_API_KEY=CHANGE_ME_DEV_API_KEY
# Required when MEMCORE_AUTH_MODE=database
MEMCORE_API_KEY_PEPPER=CHANGE_ME_API_KEY_PEPPER

# =============================================================================
# Storage / database
# =============================================================================
MEMCORE_STORAGE_MODE=embedded
MEMCORE_FACT_BACKEND=sqlite
MEMCORE_EVENT_BACKEND=sqlite
MEMCORE_DATABASE_URL=sqlite://./data/memcore.db
# Required when fact/event backend is postgres:
# MEMCORE_POSTGRES_URL=postgres://memcore:CHANGE_ME@localhost:5432/memcore

MEMCORE_DATABASE_MIGRATIONS_ENABLED=true
MEMCORE_DATABASE_MIGRATION_MODE=auto
MEMCORE_DATABASE_REQUIRE_CLEAN_MIGRATIONS=true

# =============================================================================
# Vector store
# =============================================================================
# Explicit mock avoids defaulting to LanceDB when unset.
MEMCORE_VECTOR_BACKEND=mock
# MEMCORE_QDRANT_URL=http://localhost:6333
# MEMCORE_QDRANT_COLLECTION=memcore_vectors
# MEMCORE_LANCEDB_PATH=./data/lancedb
# MEMCORE_LANCEDB_TABLE=memcore_vectors

# =============================================================================
# LLM / embedding providers
# =============================================================================
MEMCORE_LLM_PROVIDER=mock
MEMCORE_LLM_MODEL=mock-llm
MEMCORE_EMBEDDING_PROVIDER=mock
MEMCORE_EMBEDDING_MODEL=mock-embedding
# OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Redis / context cache (optional; redis backend needs redis-cache feature)
# =============================================================================
MEMCORE_CONTEXT_CACHE_BACKEND=disabled
# MEMCORE_REDIS_URL=redis://:CHANGE_ME@localhost:6379/0
# MEMCORE_CONTEXT_CACHE_TTL_SECONDS=300
# MEMCORE_CONTEXT_CACHE_MAX_ENTRIES=1000
# MEMCORE_CONTEXT_CACHE_KEY_PREFIX=memcore

# =============================================================================
# Background jobs
# =============================================================================
MEMCORE_BACKGROUND_JOBS_ENABLED=false
MEMCORE_BACKGROUND_JOB_RUNNER_INTERVAL_SECONDS=60
# MEMCORE_BACKGROUND_JOB_ORG_IDS=
MEMCORE_BACKGROUND_JOB_LOCK_ENABLED=false
MEMCORE_BACKGROUND_JOB_RETRIES_ENABLED=true
MEMCORE_GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=30
MEMCORE_BACKGROUND_JOB_SHUTDOWN_TIMEOUT_SECONDS=30

# =============================================================================
# Rate limits / quotas / retention
# =============================================================================
MEMCORE_RATE_LIMIT_ENABLED=true
MEMCORE_RATE_LIMIT_REQUESTS_PER_MINUTE=60
MEMCORE_QUOTAS_ENABLED=false
MEMCORE_RETENTION_ENABLED=false
MEMCORE_ENABLE_PII_REDACTION=true
MEMCORE_MIN_IMPORTANCE=0.55

# =============================================================================
# Security / CORS
# =============================================================================
MEMCORE_SECURITY_HEADERS_ENABLED=true
MEMCORE_MAX_REQUEST_BODY_BYTES=1048576
MEMCORE_CORS_ENABLED=false
# MEMCORE_CORS_ALLOWED_ORIGINS=
MEMCORE_CORS_ALLOW_CREDENTIALS=false

# =============================================================================
# Backup
# =============================================================================
MEMCORE_BACKUP_ENABLED=false
MEMCORE_BACKUP_DIR=./backups
MEMCORE_BACKUP_MAX_FILES=10
MEMCORE_RESTORE_ENABLED=false

# =============================================================================
# Observability
# =============================================================================
MEMCORE_LOG_FORMAT=pretty
MEMCORE_LOG_LEVEL=info
MEMCORE_REQUEST_ID_HEADER=X-Request-ID
MEMCORE_METRICS_ENABLED=true

# =============================================================================
# Release metadata (build-time; optional at runtime)
# =============================================================================
# MEMCORE_BUILD_GIT_SHA=unknown
# MEMCORE_BUILD_TIMESTAMP=unknown
# MEMCORE_BUILD_PROFILE=release

# =============================================================================
# Docker Compose Postgres bootstrap only (not read by memcore Settings)
# =============================================================================
# POSTGRES_DB=memcore
# POSTGRES_USER=memcore
# POSTGRES_PASSWORD=CHANGE_ME
