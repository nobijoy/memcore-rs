# Example environment for local development and Docker Compose.
# Copy to `.env` and replace placeholder values before deploying.
# Do not commit real secrets.
#
# Local binary: `load_settings()` loads `.env` automatically (optional).
# Docker Compose: use `docker compose --env-file .env ...` or set variables in compose.
# Production: prefer real environment variables from your platform or secret manager.

MEMCORE_ENV=production
MEMCORE_PORT=8080

MEMCORE_STORAGE_MODE=production
MEMCORE_FACT_BACKEND=postgres
MEMCORE_EVENT_BACKEND=postgres
MEMCORE_POSTGRES_URL=postgres://memcore:memcore_password@postgres:5432/memcore

MEMCORE_VECTOR_BACKEND=qdrant
MEMCORE_QDRANT_URL=http://qdrant:6333
MEMCORE_QDRANT_COLLECTION=memcore_vectors

MEMCORE_LLM_PROVIDER=mock
MEMCORE_EMBEDDING_PROVIDER=mock

# Auth: use database mode with seeded API keys for real production.
MEMCORE_AUTH_MODE=dev
MEMCORE_DEV_API_KEY=change_this_dev_key
MEMCORE_API_KEY_PEPPER=change_this_pepper

# Optional OpenAI providers (uncomment and set OPENAI_API_KEY):
# MEMCORE_LLM_PROVIDER=openai
# MEMCORE_LLM_MODEL=gpt-4.1-mini
# MEMCORE_EMBEDDING_PROVIDER=openai
# MEMCORE_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=your_openai_api_key_here

# Provider timeout/retry (see docs/PROVIDERS.md):
# MEMCORE_PROVIDER_TIMEOUT_SECONDS=30
# MEMCORE_PROVIDER_MAX_RETRIES=2
# MEMCORE_PROVIDER_INITIAL_BACKOFF_MS=250
# MEMCORE_PROVIDER_MAX_BACKOFF_MS=2000
# MEMCORE_PROVIDER_BACKOFF_MULTIPLIER=2.0
# MEMCORE_PROVIDER_RETRY_JITTER_ENABLED=true

# Provider fallback (disabled by default; see docs/PROVIDERS.md):
# MEMCORE_PROVIDER_FALLBACK_ENABLED=false
# MEMCORE_LLM_FALLBACK_ORDER=mock,openai
# MEMCORE_EMBEDDING_FALLBACK_ORDER=mock,openai
# MEMCORE_SUMMARIZER_FALLBACK_ORDER=mock,openai

# Provider circuit breaker (process-local):
# MEMCORE_PROVIDER_CIRCUIT_BREAKER_ENABLED=true
# MEMCORE_PROVIDER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# MEMCORE_PROVIDER_CIRCUIT_BREAKER_RESET_TIMEOUT_SECONDS=60
# MEMCORE_PROVIDER_CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=1

# Optional Redis context cache (requires memcore-api built with redis-cache feature):
# MEMCORE_CONTEXT_CACHE_BACKEND=redis
# MEMCORE_REDIS_URL=redis://localhost:6379
# MEMCORE_CONTEXT_CACHE_TTL_SECONDS=300
# MEMCORE_CONTEXT_CACHE_KEY_PREFIX=memcore
# MEMCORE_CONTEXT_CACHE_STAMPEDE_PROTECTION_ENABLED=true
# MEMCORE_CONTEXT_CACHE_LOCK_TIMEOUT_SECONDS=30
# MEMCORE_CONTEXT_CACHE_STALE_WHILE_REVALIDATE_ENABLED=false
# MEMCORE_CONTEXT_CACHE_STALE_TTL_SECONDS=120
# MEMCORE_CONTEXT_CACHE_METRICS_ENABLED=true

# Postgres credentials (must match docker-compose.prod.yml postgres service):
POSTGRES_DB=memcore
POSTGRES_USER=memcore
POSTGRES_PASSWORD=memcore_password
