# Staging-shaped environment (Postgres + Qdrant recommended).
# Copy to `.env.staging` (or inject via secret manager). Placeholders only.
#
# Compose: docker compose --env-file .env.staging -f docker/docker-compose.prod.yml up --build
# Build features required: postgres,qdrant  (see docker/Dockerfile CARGO_FEATURES)
#
# Never commit real secrets. Prefer secret manager over files in shared hosts.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
MEMCORE_ENV=production
MEMCORE_HOST=0.0.0.0
MEMCORE_PORT=8080

# -----------------------------------------------------------------------------
# Auth
# Prefer MEMCORE_AUTH_MODE=database with seeded keys for shared staging.
# -----------------------------------------------------------------------------
MEMCORE_AUTH_ENABLED=true
MEMCORE_AUTH_MODE=dev
MEMCORE_DEV_API_KEY=CHANGE_ME_STAGING_DEV_KEY
MEMCORE_API_KEY_PEPPER=CHANGE_ME_STAGING_PEPPER

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
MEMCORE_STORAGE_MODE=production
MEMCORE_FACT_BACKEND=postgres
MEMCORE_EVENT_BACKEND=postgres
MEMCORE_POSTGRES_URL=postgres://memcore:CHANGE_ME@postgres:5432/memcore
MEMCORE_DATABASE_MIGRATIONS_ENABLED=true
MEMCORE_DATABASE_MIGRATION_MODE=auto
MEMCORE_DATABASE_REQUIRE_CLEAN_MIGRATIONS=true

# Docker Postgres bootstrap (compose only; must match URL credentials):
POSTGRES_DB=memcore
POSTGRES_USER=memcore
POSTGRES_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# Vector store (Qdrant)
# -----------------------------------------------------------------------------
MEMCORE_VECTOR_BACKEND=qdrant
MEMCORE_QDRANT_URL=http://qdrant:6333
MEMCORE_QDRANT_COLLECTION=memcore_vectors

# -----------------------------------------------------------------------------
# LLM / embedding
# Keep mock for cost-free staging, or set OpenAI via secret manager.
# -----------------------------------------------------------------------------
MEMCORE_LLM_PROVIDER=mock
MEMCORE_LLM_MODEL=mock-llm
MEMCORE_EMBEDDING_PROVIDER=mock
MEMCORE_EMBEDDING_MODEL=mock-embedding
# MEMCORE_LLM_PROVIDER=openai
# MEMCORE_LLM_MODEL=gpt-4.1-mini
# MEMCORE_EMBEDDING_PROVIDER=openai
# MEMCORE_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
# OPENAI_BASE_URL=https://api.openai.com/v1

# Provider resilience
MEMCORE_PROVIDER_TIMEOUT_SECONDS=30
MEMCORE_PROVIDER_MAX_RETRIES=2
MEMCORE_PROVIDER_FALLBACK_ENABLED=false
MEMCORE_PROVIDER_CIRCUIT_BREAKER_ENABLED=true
MEMCORE_PROVIDER_USAGE_METRICS_ENABLED=true
MEMCORE_PROVIDER_USAGE_PERSISTENCE_ENABLED=false

# -----------------------------------------------------------------------------
# Redis / cache (optional)
# -----------------------------------------------------------------------------
MEMCORE_CONTEXT_CACHE_BACKEND=disabled
# MEMCORE_CONTEXT_CACHE_BACKEND=redis
# MEMCORE_REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# -----------------------------------------------------------------------------
# Background jobs
# -----------------------------------------------------------------------------
MEMCORE_BACKGROUND_JOBS_ENABLED=false
MEMCORE_BACKGROUND_JOB_LOCK_ENABLED=false
MEMCORE_BACKGROUND_JOB_RETRIES_ENABLED=true
MEMCORE_GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=30
MEMCORE_BACKGROUND_JOB_SHUTDOWN_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Rate limits / quotas / security
# -----------------------------------------------------------------------------
MEMCORE_RATE_LIMIT_ENABLED=true
MEMCORE_RATE_LIMIT_REQUESTS_PER_MINUTE=120
MEMCORE_QUOTAS_ENABLED=false
MEMCORE_SECURITY_HEADERS_ENABLED=true
MEMCORE_MAX_REQUEST_BODY_BYTES=1048576
MEMCORE_CORS_ENABLED=false
MEMCORE_CORS_ALLOW_CREDENTIALS=false
MEMCORE_ENABLE_PII_REDACTION=true

# -----------------------------------------------------------------------------
# Backup
# -----------------------------------------------------------------------------
MEMCORE_BACKUP_ENABLED=false
MEMCORE_BACKUP_DIR=./backups
MEMCORE_BACKUP_MAX_FILES=10
MEMCORE_RESTORE_ENABLED=false

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
MEMCORE_LOG_FORMAT=json
MEMCORE_LOG_LEVEL=info
MEMCORE_REQUEST_ID_HEADER=X-Request-ID
MEMCORE_METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# Release metadata (set at image/binary build time when possible)
# -----------------------------------------------------------------------------
# MEMCORE_BUILD_GIT_SHA=unknown
# MEMCORE_BUILD_TIMESTAMP=unknown
# MEMCORE_BUILD_PROFILE=release
