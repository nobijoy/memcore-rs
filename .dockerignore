# Keep the Docker build context small and free of secrets / local artifacts.
# Context is the repository root (see docker-compose *.yml).

.git/
.github/
.vscode/
.idea/
target/
node_modules/

.env
.env.*
!.env.example

backups/
data/
*.db
*.sqlite
*.log

